<Window x:Class="EdgeLoop.Windows.ChoiceDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EdgeLoop.Windows"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}" Width="520" 
        SizeToContent="Height" MinHeight="200"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" Background="Transparent"
        Icon="pack://application:,,,/Images/icon.ico"
        ShowInTaskbar="False">
    <Border x:Name="MainBorder" 
            Background="{StaticResource BackgroundPrimary}" 
            BorderBrush="{StaticResource AccentPrimary}" 
            BorderThickness="1"
            CornerRadius="8"
            SizeChanged="MainBorder_SizeChanged">
        <Border.Clip>
            <RectangleGeometry x:Name="MainBorderClip" RadiusX="8" RadiusY="8"/>
        </Border.Clip>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border x:Name="HeaderBorder" CornerRadius="8,8,0,0" 
                    Height="50"
                    Grid.Row="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#3D0A1F" Offset="0"/>
                        <GradientStop Color="#3D0A1F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Image Source="pack://application:,,,/Images/icon.ico" Width="20" Height="20" Margin="0,0,10,0">
                            <Image.Effect>
                                <DropShadowEffect Color="#FF69B4" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </Image.Effect>
                        </Image>
                        <TextBlock Text="{Binding DialogTitle}" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="2" Style="{StaticResource ControlButton}" 
                            Click="CancelButton_Click" 
                            Width="50" Height="50" 
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0">
                        <Path Data="{StaticResource Icon_Close}" Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Content Area -->
            <StackPanel Margin="24,24,24,20" Grid.Row="1">
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Path Data="{StaticResource Icon_Warning}" Fill="#FF4C4C" Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Top" Margin="0,4,16,0"/>
                    <TextBlock Grid.Column="1" 
                               Text="{Binding Message}" 
                               Foreground="{StaticResource TextPrimary}" 
                               FontSize="14"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                </Grid>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock x:Name="TimerText" 
                               Text="{Binding CountdownText}" 
                               Foreground="{StaticResource TextTertiary}" 
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="24,0,24,24" 
                        Grid.Row="2">
                <Button x:Name="Option1Button" 
                        Click="Option1Button_Click"
                        Margin="5,0" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Padding="20,10">
                    <TextBlock Text="{Binding Option1Text}"/>
                </Button>
                <Button x:Name="Option2Button" 
                        Click="Option2Button_Click"
                        Margin="5,0" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        FontSize="14"
                        FontWeight="Bold"
                        Padding="20,10">
                    <TextBlock Text="{Binding Option2Text}"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
