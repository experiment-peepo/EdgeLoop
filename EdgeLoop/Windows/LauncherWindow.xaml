<Window x:Class="EdgeLoop.Windows.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EdgeLoop.Windows"
        xmlns:vm="clr-namespace:EdgeLoop.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="EDGELOOP" Width="700" Height="750" MinWidth="600" MinHeight="400"
        ResizeMode="CanResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" Background="Transparent"
        Icon="pack://application:,,,/Images/icon.ico"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        SizeChanged="Window_SizeChanged"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        >
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" 
                     ResizeBorderThickness="5" 
                     GlassFrameThickness="0" 
                     CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:PluralConverter x:Key="PluralConverter"/>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:StatusMessageTypeToBrushConverter x:Key="StatusMessageTypeToBrushConverter"/>
        <local:StatusMessageTypeToForegroundConverter x:Key="StatusMessageTypeToForegroundConverter"/>
        <local:ValidationStatusToBrushConverter x:Key="ValidationStatusToBrushConverter"/>
        <local:ValidationStatusToIconConverter x:Key="ValidationStatusToIconConverter"/>
        <local:ValidationStatusToOpacityConverter x:Key="ValidationStatusToOpacityConverter"/>
        <local:ValidationStatusToForegroundConverter x:Key="ValidationStatusToForegroundConverter"/>
        <local:OpacityToIntConverter x:Key="OpacityToIntConverter"/>
        <local:OpacityScaleConverter x:Key="OpacityScaleConverter"/>
        <local:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <local:InvertedBooleanConverter x:Key="InvertedBooleanConverter"/>
        <local:IsProgressIndeterminateConverter x:Key="IsProgressIndeterminateConverter"/>
        
        <Style x:Key="ActivePlayerButtonStyle" TargetType="Button" BasedOn="{StaticResource ControlButton}">
            <Setter Property="Foreground" Value="{StaticResource AccentPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" 
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                             VerticalAlignment="Center"
                                             Content="{TemplateBinding Content}"
                                             ContentTemplate="{TemplateBinding ContentTemplate}"
                                             RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MainActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BackgroundSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="13"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentPrimary}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentSecondary}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#CC1493"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TrainingToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource MainButton}">
            <Setter Property="Background" Value="{StaticResource AccentPrimary}"/>
            <Setter Property="Command" Value="{Binding HypnotizeCommand}"/>
            <Setter Property="IsEnabled" Value="{Binding IsHypnotizeEnabled}"/>
            <Setter Property="ToolTip" Value="Start playback on all assigned screens"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="24,12"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActivePlayers}" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="Command" Value="{Binding DehypnotizeCommand}"/>
                    <Setter Property="IsEnabled" Value="True"/>
                    <Setter Property="ToolTip" Value="Stop all active playback sessions"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasActivePlayers}" Value="True"/>
                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource ErrorColor}"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Border x:Name="MainBorder" 
            Background="{StaticResource BackgroundPrimary}" 
            BorderBrush="{StaticResource AccentPrimary}" 
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 0: Title Bar -->
                <RowDefinition Height="Auto"/> <!-- 1: App Header (Logo, Actions) -->
                <RowDefinition Height="Auto"/> <!-- 2: Playlist Header (Controls) -->
                <RowDefinition Height="*"/>    <!-- 3: Playlist Area (Scrollable) -->
                <RowDefinition Height="Auto"/> <!-- 4: Status Area -->
                <RowDefinition Height="Auto"/> <!-- 5: Active Players Area -->
                <RowDefinition Height="Auto"/> <!-- 6: Footer Actions -->
            </Grid.RowDefinitions>

            <!-- Header (Title Bar) -->
            <Border x:Name="HeaderBorder" CornerRadius="8,8,0,0" Height="50" Grid.Row="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#3D0A1F" Offset="0"/>
                        <GradientStop Color="#3D0A1F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Image Source="pack://application:,,,/Images/icon.ico" Width="20" Height="20" Margin="0,0,10,0">
                            <Image.Effect>
                                <DropShadowEffect Color="#FF69B4" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                            </Image.Effect>
                        </Image>
                        <TextBlock Text="EDGELOOP" Foreground="White" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" FontFamily="Segoe UI, sans-serif"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                        <Button Style="{StaticResource ControlButton}" Click="AboutButton_Click" Width="36" Height="50" ToolTip="About EDGELOOP" Padding="0">
                            <Path Data="{StaticResource Icon_Info}" Stretch="Uniform" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource ControlButton}" Click="SettingsButton_Click" Width="36" Height="50" ToolTip="Open settings" Padding="0">
                            <Path Data="{StaticResource Icon_Settings}" Stretch="Uniform" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource ControlButton}" Command="{Binding MinimizeCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Width="36" Height="50" ToolTip="Minimize window" Padding="0">
                            <Path Data="{StaticResource Icon_Minimize}" Stretch="Uniform" Width="12" Height="12"/>
                        </Button>
                        <Button x:Name="MaximizeButton" Style="{StaticResource ControlButton}" Click="MaximizeButton_Click" Width="36" Height="50" ToolTip="Maximize/Restore window" Padding="0">
                            <Path Stretch="Uniform" Width="12" Height="12">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        <Setter Property="Data" Value="{StaticResource Icon_Maximize}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                                <Setter Property="Data" Value="{StaticResource Icon_Restore}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>
                        <Button Style="{StaticResource ControlButton}" Command="{Binding ExitCommand}" Width="44" Height="50" Background="Transparent" Foreground="White" BorderThickness="0" ToolTip="Exit application" Padding="0">
                            <Path Data="{StaticResource Icon_Close}" Stretch="Uniform" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Row 1: App Header Section (Logo, Actions) -->
            <StackPanel Grid.Row="1" Margin="24,12,24,12">
                <StackPanel Margin="0,10,0,20">
                    <Label Style="{StaticResource GlowingTitleStyle}" Margin="0,0,0,5">EDGELOOP</Label>
                    <TextBlock Style="{StaticResource LowerTitle}" FontStyle="Italic" FontSize="13" HorizontalAlignment="Center">Advanced Multi-Monitor Overlay Engine</TextBlock>
                </StackPanel>

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BrowseButton" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource MainActionButtonStyle}" Command="{Binding BrowseCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Folder}" Fill="{StaticResource TextPrimary}" Stretch="Uniform" Width="16" Height="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Browse Videos"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddUrlOrPlaylistButton" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource MainActionButtonStyle}" Command="{Binding AddUrlOrPlaylistCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Link}" Fill="{StaticResource TextPrimary}" Stretch="Uniform" Width="16" Height="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Add URL"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Row 2: Playlist Header Controls -->
            <Grid Grid.Row="2" Margin="24,0,24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource LowerTitle}" VerticalAlignment="Center" Margin="0">
                        <Run Text="Playlist" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                        <Run Text=" (" Foreground="{StaticResource TextSecondary}" FontSize="13"/><Run Text="{Binding AddedFiles.Count, Mode=OneWay}" Foreground="{StaticResource TextSecondary}" FontSize="13"/><Run Text=" videos)" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                    </TextBlock>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Full View Buttons -->
                    <StackPanel x:Name="FullPlaylistButtons" Orientation="Horizontal">
                        <Button Command="{Binding LoadPlaylistCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,4" Margin="0,0,8,0" Height="32">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Folder}" Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="12" Height="12" Margin="0,0,8,0"/>
                                <TextBlock Text="Load" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SavePlaylistCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,4" Margin="0,0,8,0" Height="32">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Save}" Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="12" Height="12" Margin="0,0,8,0"/>
                                <TextBlock Text="Save" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ClearAllCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,4" Height="32">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon_Trash}" Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="12" Height="12" Margin="0,0,8,0"/>
                                <TextBlock Text="Clear" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Compact View Buttons (Icon only) -->
                    <StackPanel x:Name="CompactPlaylistButtons" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Command="{Binding LoadPlaylistCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="36" Height="32" Margin="0,0,4,0" ToolTip="Load Playlist">
                            <Path Data="{StaticResource Icon_Folder}" Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="14" Height="14"/>
                        </Button>
                        <Button Command="{Binding SavePlaylistCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="36" Height="32" Margin="0,0,4,0" ToolTip="Save Playlist">
                            <Path Data="{StaticResource Icon_Save}" Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="14" Height="14"/>
                        </Button>
                        <Button Command="{Binding ClearAllCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="36" Height="32" ToolTip="Clear All">
                            <Path Data="{StaticResource Icon_Trash}" Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Row 3: Playlist Area (The ONLY Scrollable Section) -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border Padding="24,0,24,0">
                    <Grid MinHeight="200">
                        <Border Background="Black" Opacity="0.2" CornerRadius="8"/>
                        <Border x:Name="PlaylistDropZone" CornerRadius="8" BorderThickness="2.5" BorderBrush="Transparent">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="Tag" Value="DragOver">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentPrimary}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ListView x:Name="AddedFilesList" 
                                      ItemsSource="{Binding AddedFiles}" 
                                      Background="Transparent" 
                                      BorderThickness="0" 
                                      Padding="0" 
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      AllowDrop="True"
                                      PreviewMouseLeftButtonDown="AddedFilesList_PreviewMouseLeftButtonDown"
                                      MouseMove="AddedFilesList_MouseMove"
                                      Drop="AddedFilesList_Drop"
                                      DragOver="AddedFilesList_DragOver"
                                      DragEnter="AddedFilesList_DragEnter"
                                      DragLeave="AddedFilesList_DragLeave">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListViewItem"><ContentPresenter /></ControlTemplate></Setter.Value></Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Margin="0,8,0,8" Padding="20" Background="{StaticResource BackgroundSecondary}" BorderThickness="1.5" BorderBrush="#4DFF1493">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#FF1493" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Width="24" Height="24" Margin="0,0,12,0">
                                                        <Border Background="{StaticResource AccentPrimary}" CornerRadius="4" Visibility="{Binding IsUrl, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <Path Data="{StaticResource Icon_Globe}" Fill="White" Stretch="Uniform" Margin="4"/>
                                                        </Border>
                                                        <Border Background="{StaticResource SuccessColor}" CornerRadius="4" Visibility="{Binding IsUrl, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                                                            <Path Data="{StaticResource Icon_File}" Fill="White" Stretch="Uniform" Margin="4"/>
                                                        </Border>
                                                    </Grid>
                                                     <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,2,0,0">
                                                         <TextBlock Text="{Binding FileName}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
                                                         <TextBlock Text="{Binding SourceName}" Foreground="{StaticResource TextTertiary}" FontSize="11" FontStyle="Italic"/>
                                                     </StackPanel>
                                                    <ComboBox Grid.Column="2" ItemsSource="{Binding DataContext.AvailableScreens, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding AssignedScreen}" Style="{StaticResource PinkComboBoxStyle}" Width="220" Margin="12,0"/>
                                                    <Button Grid.Column="3" Style="{StaticResource ControlButton}" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Width="24" Height="24" Margin="8,0,0,0">
                                                        <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="10" Height="10"/>
                                                    </Button>
                                                </Grid>
                                                <Grid Grid.Row="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Opacity" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <Slider Grid.Column="1" Value="{Binding Opacity, Converter={StaticResource OpacityScaleConverter}}" Minimum="0" Maximum="1" TickFrequency="0.1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Style="{StaticResource NeonSliderStyle}"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Opacity, Converter={StaticResource OpacityToIntConverter}}" Width="30" TextAlignment="Right" Foreground="{StaticResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4" Text="Volume" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <Slider Grid.Column="5" Value="{Binding Volume}" Minimum="0" Maximum="1" TickFrequency="0.1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Style="{StaticResource NeonSliderStyle}"/>
                                                    <TextBlock Grid.Column="6" Text="{Binding Volume, StringFormat=P0}" Width="35" TextAlignment="Right" Foreground="{StaticResource TextPrimary}" FontSize="12" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                        
                        <!-- Empty State Overlay -->
                        <Grid IsHitTestVisible="False" Visibility="{Binding HasItems, ElementName=AddedFilesList, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon_Folder}" Fill="{StaticResource AccentSecondary}" Stretch="Uniform" Width="72" Height="72" Opacity="0.4" Margin="0,0,0,24"/>
                                <TextBlock Text="Drag &amp; Drop videos here" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="or click Browse to add files" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" FontSize="13" FontStyle="Italic"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </ScrollViewer>

            <!-- Row 4: Status Area -->
            <Border x:Name="StatusBorder" Grid.Row="4" Background="{Binding StatusMessageType, Converter={StaticResource StatusMessageTypeToBrushConverter}}" CornerRadius="8" Margin="24,12,24,0" Padding="16,10" Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusMessageType, Converter={StaticResource StatusMessageTypeToForegroundConverter}}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
            </Border>

            <!-- Row 5: Currently Playing sticky area -->
            <StackPanel Grid.Row="5" Margin="24,12,24,0" Visibility="{Binding HasActivePlayers, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Style="{StaticResource LowerTitle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8">Currently Playing</TextBlock>
                <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ActivePlayers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,8,8" CornerRadius="8" BorderBrush="{StaticResource AccentPrimary}" BorderThickness="1.5" Background="#1A0510">
                                    <StackPanel Margin="16,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ScreenName}" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="|" Margin="10,0" Opacity="0.3" Foreground="White"/>
                                                <TextBlock Text="{Binding CurrentVideoTitle}" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Command="{Binding TogglePlayPauseCommand}" Style="{StaticResource ActivePlayerButtonStyle}">
                                                <Path Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="14" Height="14">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Data" Value="{StaticResource Icon_Play}"/>
                                                            <Style.Triggers><DataTrigger Binding="{Binding IsPlaying}" Value="True"><Setter Property="Data" Value="{StaticResource Icon_Pause}"/></DataTrigger></Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Button>
                                            <Button Grid.Column="2" Command="{Binding SkipCommand}" Style="{StaticResource ActivePlayerButtonStyle}">
                                                <Path Data="{StaticResource Icon_Next}" Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="14" Height="14"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <!-- Row 6: Playback Actions sticky footer -->
            <Border Grid.Row="6" Background="{StaticResource BackgroundPrimary}" BorderBrush="{StaticResource BorderPink}" BorderThickness="0,1,0,0" Padding="24,20,24,24" CornerRadius="0,0,8,8">
                <StackPanel>
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource LowerTitle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,12,0" VerticalAlignment="Center">Shuffle</TextBlock>
                        <CheckBox x:Name="ShuffleCheckBox" IsChecked="{Binding Shuffle}" Grid.Column="1" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Button x:Name="TrainingToggleButton" Style="{StaticResource TrainingToggleButtonStyle}" HorizontalAlignment="Stretch"
                            CommandParameter="{Binding ElementName=AddedFilesList, Path=SelectedItems}">
                        <Button.Content>
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding HasActivePlayers, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                                    <Path Data="{StaticResource Icon_Play}" Stretch="Uniform" Width="12" Height="12" Fill="White" Margin="0,0,10,0"/>
                                    <TextBlock Text="Start Playback" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding HasActivePlayers, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Path Data="{StaticResource Icon_Stop}" Stretch="Uniform" Width="14" Height="14" Fill="Black" Margin="0,0,10,0"/>
                                    <TextBlock Text="Stop Playback" Foreground="Black" FontWeight="SemiBold" FontSize="15"/>
                                </StackPanel>
                            </Grid>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Busy Indicator Overlay (Spans all rows) -->
            <Grid Grid.RowSpan="7" Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="1000">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid Width="60" Height="60">
                        <Grid.RenderTransform><RotateTransform x:Name="UnifiedSpinnerTransform" CenterX="30" CenterY="30"/></Grid.RenderTransform>
                        <Grid.Triggers><EventTrigger RoutedEvent="Loaded"><BeginStoryboard><Storyboard RepeatBehavior="Forever"><DoubleAnimation Storyboard.TargetName="UnifiedSpinnerTransform" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1.5"/></Storyboard></BeginStoryboard></EventTrigger></Grid.Triggers>
                        <Path Data="M 30,0 A 30,30 0 0 1 60,30" Stroke="{StaticResource AccentPrimary}" StrokeThickness="5"/>
                        <Path Data="M 60,30 A 30,30 0 0 1 0,30" Stroke="{StaticResource TextSecondary}" StrokeThickness="5" Opacity="0.3"/>
                    </Grid>
                    <TextBlock Text="{Binding ImportProgressText}" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,20,0,10"/>
                    <ProgressBar Width="200" Height="4" Value="{Binding ImportProgressValue}" Background="#30FFFFFF" Foreground="{StaticResource AccentPrimary}" IsIndeterminate="{Binding ImportProgressValue, Converter={StaticResource IsProgressIndeterminateConverter}}"/>
                    <Button Command="{Binding CancelImportCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,20,0,0" Padding="30,8" Content="Cancel Import"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
