<Window x:Class="EdgeLoop.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EdgeLoop.Windows"
        xmlns:vm="clr-namespace:EdgeLoop.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="Settings" SizeToContent="Height" Width="480"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" Background="Transparent"
        Icon="pack://application:,,,/Images/icon.ico"
        ShowInTaskbar="False">
    <Window.Resources>
        <local:OpacityToIntConverter x:Key="OpacityToIntConverter"/>
        <local:OpacityScaleConverter x:Key="OpacityScaleConverter"/>
        <local:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <x:Array x:Key="KeyList" Type="sys:String">
            <sys:String>End</sys:String>
            <sys:String>Escape</sys:String>
            <sys:String>Space</sys:String>
            <sys:String>F1</sys:String>
            <sys:String>F2</sys:String>
            <sys:String>F3</sys:String>
            <sys:String>F4</sys:String>
            <sys:String>F5</sys:String>
            <sys:String>F6</sys:String>
            <sys:String>F7</sys:String>
            <sys:String>F8</sys:String>
            <sys:String>F9</sys:String>
            <sys:String>F10</sys:String>
            <sys:String>F11</sys:String>
            <sys:String>F12</sys:String>
            <sys:String>Delete</sys:String>
            <sys:String>Insert</sys:String>
            <sys:String>Home</sys:String>
            <sys:String>PageUp</sys:String>
            <sys:String>PageDown</sys:String>
            <sys:String>NumPad0</sys:String>
            <sys:String>NumPad1</sys:String>
            <sys:String>NumPad2</sys:String>
            <sys:String>NumPad3</sys:String>
            <sys:String>NumPad4</sys:String>
            <sys:String>NumPad5</sys:String>
            <sys:String>NumPad6</sys:String>
            <sys:String>NumPad7</sys:String>
            <sys:String>NumPad8</sys:String>
            <sys:String>NumPad9</sys:String>
            <sys:String>Left</sys:String>
            <sys:String>Right</sys:String>
            <sys:String>Up</sys:String>
            <sys:String>Down</sys:String>
        </x:Array>

        <!-- Modern Collapsible Section Style -->
        <Style x:Key="SettingsExpanderStyle" TargetType="{x:Type Expander}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Expander}">
                        <Grid Margin="0,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition x:Name="ContentRow" Height="0"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <ToggleButton x:Name="HeaderSite"
                                          Background="{TemplateBinding Background}"
                                          BorderThickness="0"
                                          Content="{TemplateBinding Header}"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Padding="0,15"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="{TemplateBinding Background}" IsHitTestVisible="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <ContentPresenter Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0">
                                                    <ContentPresenter.Resources>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="FontSize" Value="16"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                        </Style>
                                                    </ContentPresenter.Resources>
                                                </ContentPresenter>
                                                
                                                <Path x:Name="Arrow"
                                                      Grid.Column="1"
                                                      Data="M 1,1 L 7,7 L 13,1"
                                                      Stroke="{StaticResource TextSecondary}"
                                                      StrokeThickness="2"
                                                      VerticalAlignment="Center"
                                                      Margin="10,0,5,0"
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource AccentPrimary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            
                            <Border x:Name="ExpandSite"
                                    Grid.Row="1"
                                    Visibility="Collapsed"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Padding="10,10,10,20">
                                <Border.Resources>
                                    <!-- Locally override the global Label style that has the glow/margin issues -->
                                    <Style TargetType="Label">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Effect" Value="{x:Null}"/>
                                    </Style>
                                </Border.Resources>
                                <ContentPresenter/>
                            </Border>
                            
                            <Border Grid.Row="2" 
                                    Height="1" 
                                    Background="#22FFFFFF" 
                                    Margin="0,5,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentRow" Property="Height" Value="Auto"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border x:Name="MainBorder" 
            Background="{StaticResource BackgroundPrimary}" 
            BorderBrush="{StaticResource AccentPrimary}" 
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with modernized title and subtitle -->
            <Grid Grid.Row="0" Margin="20,24,20,0" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Settings" Style="{StaticResource WindowHeaderTitleStyle}"/>
                    <TextBlock Text="Manage playback settings, display preferences, and application options" Style="{StaticResource WindowHeaderSubtitleStyle}"/>
                </StackPanel>
                <Button Style="{StaticResource ControlButton}" 
                        Click="CloseButton_Click" 
                        ToolTip="Close settings"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="30" Height="30"
                        Background="Transparent"
                        Foreground="{StaticResource TextSecondary}">
                    <Path Data="{StaticResource Icon_Close}" Stretch="Uniform" Width="12" Height="12"/>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="24,20,24,0" Padding="0,0,10,0">
                <StackPanel>
                    <!-- Playback Settings -->
                    <Expander Header="Playback" Style="{StaticResource SettingsExpanderStyle}" IsExpanded="{Binding IsPlaybackExpanded}">
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Default Monitor -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,20" VerticalAlignment="Center">
                                <TextBlock Text="Default Monitor" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Monitor used by default for new videos" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Row="0" Grid.Column="1" Width="180"
                                      ItemsSource="{Binding AvailableMonitors}"
                                      SelectedItem="{Binding SelectedDefaultMonitor}"
                                      Style="{StaticResource PinkComboBoxStyle}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,0,20"/>

                            <!-- Default Opacity -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,20" VerticalAlignment="Center">
                                <TextBlock Text="Default Opacity" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Initial opacity level for new videos" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,20">
                                <Slider Width="140" Value="{Binding DefaultOpacity, Converter={StaticResource OpacityScaleConverter}}"
                                        Minimum="0" Maximum="1.0" SmallChange="0.1" LargeChange="0.1" TickFrequency="0.1"
                                        TickPlacement="BottomRight"
                                        Style="{StaticResource NeonSliderStyle}" IsSnapToTickEnabled="True"/>
                                <TextBlock Text="{Binding DefaultOpacity, Converter={StaticResource OpacityToIntConverter}}"
                                           Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold" Width="35" TextAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- Default Volume -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,20" VerticalAlignment="Center">
                                <TextBlock Text="Default Volume" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Initial volume level for new videos" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,20">
                                <Slider Width="140" Value="{Binding DefaultVolume}"
                                        Minimum="0" Maximum="1" SmallChange="0.1" LargeChange="0.1" TickFrequency="0.1"
                                        TickPlacement="BottomRight"
                                        Style="{StaticResource NeonSliderStyle}" IsSnapToTickEnabled="True"/>
                                <TextBlock Text="{Binding DefaultVolume, StringFormat='{}{0:P0}'}" 
                                           Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold" Width="35" TextAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- Opaque Mode -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,16,20" VerticalAlignment="Center">
                                <TextBlock Text="Opaque Mode" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Disable transparency for all videos" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Row="3" Grid.Column="1" 
                                      IsChecked="{Binding AlwaysOpaque}"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,0,20"/>

                            <!-- Super Resolution (AI Upscaling) -->
                            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="AI Upscaling" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Enhance video quality using Nvidia RTX or Intel XeSS" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Row="4" Grid.Column="1" 
                                      IsChecked="{Binding EnableSuperResolution}"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      VerticalAlignment="Center"/>

                        </Grid>
                    </Expander>

                    <!-- General Settings (Application + Storage) -->
                    <Expander Header="General" Style="{StaticResource SettingsExpanderStyle}" IsExpanded="{Binding IsGeneralExpanded}">
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Always on Top -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,20" VerticalAlignment="Center">
                                <TextBlock Text="Keep Launcher on Top" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="This window stays above other windows" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Row="0" Grid.Column="1" 
                                      IsChecked="{Binding LauncherAlwaysOnTop}"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,0,20"/>
                            
                            <!-- Start with Windows -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,20" VerticalAlignment="Center">
                                <TextBlock Text="Start with Windows" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Launch EDGELOOP automatically when Windows starts" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Row="1" Grid.Column="1" 
                                      IsChecked="{Binding StartWithWindows}"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,0,20"/>

                            <!-- Divider -->
                            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Height="1" Background="#22FFFFFF" Margin="0,0,0,20"/>

                            <!-- Enable Local Caching -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,16,20" VerticalAlignment="Center">
                                <TextBlock Text="Enable Local Caching" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Download videos to disk for instant seeking and stutter-free playback" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Row="3" Grid.Column="1" 
                                      IsChecked="{Binding EnableLocalCaching}"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,0,20"/>
                            
                            <!-- Cache Directory -->
                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10" VerticalAlignment="Center">
                                <TextBlock Text="Cache Directory" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Folder where downloaded videos are stored" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding LocalCacheDirectory, UpdateSourceTrigger=PropertyChanged}" 
                                             IsReadOnly="True"
                                             Foreground="{StaticResource TextSecondary}"
                                             Height="32" Padding="8,6"
                                             VerticalContentAlignment="Center"
                                             ToolTip="{Binding LocalCacheDirectory}"/>
                                    <Button Grid.Column="1" Command="{Binding BrowseCacheDirectoryCommand}" 
                                            Style="{StaticResource SecondaryButtonStyle}" 
                                            Content="Browse..." 
                                            Margin="8,0,0,0" Height="32" Padding="12,0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Expander>

                    <!-- Privacy & History (Session + History + Cookies) -->
                    <Expander Header="Privacy &amp; History" Style="{StaticResource SettingsExpanderStyle}" IsExpanded="{Binding IsPrivacyExpanded}">
                        <StackPanel Margin="0,10,0,0">
                            <!-- Session Persistence -->
                            <TextBlock Text="SESSION PERSISTENCE" Foreground="{StaticResource AccentPrimary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,12" Opacity="0.85"/>
                            
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Remember last playlist" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Automatically load your last playlist on startup" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding RememberLastPlaylist}" Style="{StaticResource ModernCheckBoxStyle}" VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Remember file position" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Resume videos from where you left off" Style="{StaticResource CaptionText}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" IsChecked="{Binding RememberFilePosition}" Style="{StaticResource ModernCheckBoxStyle}" VerticalAlignment="Center"/>
                            </Grid>

                            <Button Command="{Binding ResetPositionsCommand}" Style="{StaticResource DangerButtonStyle}" Height="32" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource Icon_Trash}" Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Reset All Saved Positions" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <!-- Web Sessions & Cookies -->
                            <Border Height="1" Background="#22FFFFFF" Margin="0,0,0,20"/>
                            <TextBlock Text="WEB SESSIONS &amp; COOKIES" Foreground="{StaticResource AccentPrimary}" FontSize="11" FontWeight="Bold" Margin="0,0,0,12" Opacity="0.85"/>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Browser for Cookies" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Select the browser where you are logged in to YouTube/Vimeo" Style="{StaticResource CaptionText}" Margin="0,4,0,8"/>
                                <ComboBox ItemsSource="{Binding AvailableBrowsers}" SelectedItem="{Binding BrowserForCookies}" Style="{StaticResource PinkComboBoxStyle}" Height="32"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Hypnotube Session Cookies" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Format: PHPSESSID=xxx; other=yyy" Foreground="{StaticResource TextTertiary}" FontSize="11" Margin="0,4,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding HypnotubeCookies, UpdateSourceTrigger=PropertyChanged}" Height="32" Padding="8,6" Background="#2A2A3E" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource AccentPrimary}" BorderThickness="1" VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="1" Command="{Binding PasteHypnoCookiesCommand}" Style="{StaticResource SecondaryButtonStyle}" Height="32" Padding="12,0" Margin="8,0,0,0" Content="Paste" FontWeight="SemiBold"/>
                                </Grid>
                            </StackPanel>
                            
                            <Button Command="{Binding CopyCookieScriptCommand}" Style="{StaticResource SecondaryButtonStyle}" Height="28" HorizontalAlignment="Left" Padding="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M14.6,16.6L19.2,12L14.6,7.4L16,6L22,12L16,18L14.6,16.6M9.4,16.6L4.8,12L9.4,7.4L8,6L2,12L8,18L9.4,16.6Z" Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="12" Height="12" Margin="0,0,8,0"/>
                                    <TextBlock Text="Copy Cookie Script" FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Expander>

                    <!-- Hotkeys -->
                    <Expander Header="Hotkeys" Style="{StaticResource SettingsExpanderStyle}" IsExpanded="{Binding IsHotkeysExpanded}">
                        <StackPanel Grid.IsSharedSizeScope="True">

                            <!-- ═══ Emergency Controls ═══ -->
                            <TextBlock Text="EMERGENCY CONTROLS" 
                                       Foreground="{StaticResource AccentPrimary}" 
                                       FontSize="11" FontWeight="Bold" 
                                       Margin="0,0,0,12" 
                                       Opacity="0.85"/>

                            <!-- Panic Hotkey -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="HotkeyLabel"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Panic" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                                    <CheckBox Content="Ctrl" IsChecked="{Binding PanicHotkeyCtrl}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <CheckBox Content="Shift" IsChecked="{Binding PanicHotkeyShift}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <CheckBox Content="Alt" IsChecked="{Binding PanicHotkeyAlt}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="+" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="95" ItemsSource="{StaticResource KeyList}" SelectedItem="{Binding PanicHotkeyKey}" Style="{StaticResource PinkComboBoxStyle}"/>
                            </Grid>

                            <!-- Wipe & Exit Hotkey -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="HotkeyLabel"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Wipe &amp; Exit" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                                    <CheckBox Content="Ctrl" IsChecked="{Binding ClearHotkeyCtrl}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <CheckBox Content="Shift" IsChecked="{Binding ClearHotkeyShift}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <CheckBox Content="Alt" IsChecked="{Binding ClearHotkeyAlt}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="+" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="95" ItemsSource="{StaticResource KeyList}" SelectedItem="{Binding ClearHotkeyKey}" Style="{StaticResource PinkComboBoxStyle}"/>
                            </Grid>

                            <!-- Fullscreen Escape (Opaque Mode) -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="HotkeyLabel"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Fullscreen Escape" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Triple-press to exit" Foreground="{StaticResource TextTertiary}" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="95" ItemsSource="{StaticResource KeyList}" SelectedItem="{Binding OpaquePanicHotkeyKey}" Style="{StaticResource PinkComboBoxStyle}"/>
                            </Grid>

                            <!-- ═══ Divider ═══ -->
                            <Border Height="1" Background="#22FFFFFF" Margin="0,14,0,14"/>

                            <!-- ═══ Playback Navigation ═══ -->
                            <TextBlock Text="PLAYBACK NAVIGATION" 
                                       Foreground="{StaticResource AccentPrimary}" 
                                       FontSize="11" FontWeight="Bold" 
                                       Margin="0,0,0,12" 
                                       Opacity="0.85"/>

                            <!-- Skip Forward Hotkey -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="HotkeyLabel"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Skip Forward" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                                    <CheckBox Content="Ctrl" IsChecked="{Binding SkipForwardHotkeyCtrl}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <CheckBox Content="Shift" IsChecked="{Binding SkipForwardHotkeyShift}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <CheckBox Content="Alt" IsChecked="{Binding SkipForwardHotkeyAlt}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="+" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="95" ItemsSource="{StaticResource KeyList}" SelectedItem="{Binding SkipForwardHotkeyKey}" Style="{StaticResource PinkComboBoxStyle}"/>
                            </Grid>

                            <!-- Skip Backward Hotkey -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="HotkeyLabel"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Skip Backward" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                                    <CheckBox Content="Ctrl" IsChecked="{Binding SkipBackwardHotkeyCtrl}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <CheckBox Content="Shift" IsChecked="{Binding SkipBackwardHotkeyShift}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <CheckBox Content="Alt" IsChecked="{Binding SkipBackwardHotkeyAlt}" Style="{StaticResource ModernCheckBoxStyle}" FontSize="11" Margin="0,0,8,0" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="+" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="2" Width="95" ItemsSource="{StaticResource KeyList}" SelectedItem="{Binding SkipBackwardHotkeyKey}" Style="{StaticResource PinkComboBoxStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Expander>
 
                    <!-- Diagnostics Settings -->
                    <Expander Header="Diagnostics" Style="{StaticResource SettingsExpanderStyle}" IsExpanded="{Binding IsDiagnosticsExpanded}">
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
 
                            <!-- Diagnostic Mode -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,20" VerticalAlignment="Center">
                                <TextBlock Text="Diagnostic Mode" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Generate a separate diagnostic log with detailed file paths, engine events, and system info for troubleshooting" Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox Grid.Row="0" Grid.Column="1" 
                                      IsChecked="{Binding EnableDiagnosticMode}"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,0,20"/>

                            <!-- Open Log Folder Button -->
                            <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    Command="{Binding OpenDiagnosticsFolderCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Height="32" Padding="10,0"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Stretch="Uniform" Width="14" Height="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="Open Log Folder" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <!-- Fixed Footer with Buttons -->
            <Grid Grid.Row="2" Margin="24,20,24,24">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding CancelCommand}" 
                            Style="{StaticResource SecondaryButtonStyle}" 
                            Width="100" 
                            Height="38"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Close}" Fill="{StaticResource AccentPrimary}" Stretch="Uniform" Width="10" Height="10" Margin="0,0,8,0"/>
                            <TextBlock Text="Cancel" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OkCommand}" 
                            Style="{StaticResource PrimaryButtonStyle}" 
                            Width="150" 
                            Height="38">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon_Save}" Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Save Changes" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

